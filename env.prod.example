# Configurações de Produção
# Copie para .env.prod e configure com valores reais

# Aplicação
APP_NAME=Sistema Operacional Bom Jesus
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Servidor
HOST=0.0.0.0
PORT=8000

# Database (ALTERAR COM VALORES FORTES!)
POSTGRES_USER=bomjesus
POSTGRES_PASSWORD=<senha-forte-aleatória>
POSTGRES_DB=bom_jesus_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db-service:5432/${POSTGRES_DB}

# Segurança (ALTERAR COM VALORES FORTES!)
SECRET_KEY=<chave-secreta-forte-aleatória>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Ajustar com domínio real)
CORS_ORIGINS=["https://seu-dominio.com", "https://www.seu-dominio.com"]

# Redis (ALTERAR COM VALORES FORTES!)
REDIS_PASSWORD=<senha-forte-aleatória>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis-service:6379/0

# Frontend
NEXT_PUBLIC_API_URL=https://seu-dominio.com

# Docker Registry
DOCKER_REGISTRY=bomjesus
IMAGE_TAG=latest

# Logging
LOG_LEVEL=INFO

